# ─── Telegram ─────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=stager_bot
# CSV-список Telegram user IDs, которым НЕ нужен invite (initial admins)
TELEGRAM_WHITELIST_IDS=

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=stager
POSTGRES_PASSWORD=change-me
POSTGRES_DB=stager
DATABASE_URL=postgresql+asyncpg://stager:change-me@postgres:5432/stager

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO ─────────────────────────────────────────────────
MINIO_ROOT_USER=stager
MINIO_ROOT_PASSWORD=change-me-too
MINIO_BUCKET=stager-receipts
MINIO_ENDPOINT=http://minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000

# ─── LLM ───────────────────────────────────────────────────
# MiMo (Xiaomi Token Plan) — primary
MIMO_API_KEY=
MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
MIMO_MODEL_VISION=mimo-v2-omni
MIMO_MODEL_FAST=mimo-v2.5
MIMO_MODEL_SMART=mimo-v2.5-pro

# Google Gemini — fallback
GOOGLE_API_KEY=
GEMINI_MODEL_VISION=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_SMART=gemini-2.5-pro

# Soft circuit-breaker: после N подряд 401/403 от MiMo блокируем его на TTL секунд
LLM_MIMO_SOFT_DISABLE_AFTER=3
LLM_MIMO_SOFT_DISABLE_TTL=3600

# ─── Auth / Web ────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXP_HOURS=168
NEXT_PUBLIC_API_BASE=/api/v1

# ─── Observability ─────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ─── App ───────────────────────────────────────────────────
APP_ENV=dev
APP_DEFAULT_LOCALE=ru
